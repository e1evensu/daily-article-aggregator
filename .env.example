# ============================================================
# Intelligence System — 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ── 数据库 (MySQL@114 via SSH tunnel) ────────────────────────
DATABASE_URL=mysql+asyncmy://intelligence:PASSWORD@127.0.0.1:13306/intelligence

# ── Redis (114 via SSH tunnel) ───────────────────────────────
REDIS_URL=redis://:PASSWORD@127.0.0.1:16379/0

# ── AI 模型 (NVIDIA NIM, rate limits must be tested) ─────────
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Stage 1 模型 (全量分析)
STAGE1_MODEL=deepseek-ai/deepseek-v4-flash
# Stage 2 模型 (深度分析, ≥75 分触发)
STAGE2_MODEL=deepseek-ai/deepseek-v4-pro
# 日报生成模型
DIGEST_MODEL=deepseek-ai/deepseek-v4-flash
DIGEST_DOMAINS=security,ai

# 可选 fallback provider
SUB2API_BASE_URL=
SUB2API_API_KEY=

# 模型调用策略
STAGE1_TIMEOUT_S=120
STAGE1_RETRIES=2
STAGE1_RETRY_BACKOFF_S=2,4
STAGE1_TEMPERATURE=0.1
STAGE1_MAX_TOKENS=2048
STAGE1_CONCURRENCY=3
STAGE2_TIMEOUT_S=300
STAGE2_RETRIES=2
STAGE2_RETRY_BACKOFF_S=5,10
STAGE2_TEMPERATURE=0.2
STAGE2_MAX_TOKENS=4096
STAGE2_CONCURRENCY=1
DIGEST_TIMEOUT_S=300
DIGEST_RETRIES=2
DIGEST_RETRY_BACKOFF_S=2,4
DIGEST_TEMPERATURE=0.3
DIGEST_MAX_TOKENS=1024
DIGEST_CONCURRENCY=1
DIGEST_OVERVIEW_MAX_ITEMS=20

# ── 阿里云 OSS (日报存储 → 博客) ─────────────────────────────
OSS_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=intelligence/digests

# ── GitHub API (采集用) ──────────────────────────────────────
GITHUB_TOKEN=ghp_xxx

# ── 飞书推送 (Phase 2) ──────────────────────────────────────
FEISHU_WEBHOOK_URL=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ── 分析参数 ─────────────────────────────────────────────────
# Stage 2 触发阈值
STAGE2_THRESHOLD=75
DIGEST_CANDIDATE_THRESHOLD=40
DIGEST_TOP_N_PER_CATEGORY=5
# 实时推送阈值
REALTIME_PUSH_THRESHOLD=85

# ── 数据保留 (天数, 按 insight_score 分级) ────────────────────
RETENTION_BELOW_10=0
RETENTION_BELOW_30=5
RETENTION_BELOW_50=10
RETENTION_BELOW_75=30
RETENTION_DELETE_BELOW_SCORE=10
RETENTION_5_DAYS_BELOW_SCORE=30
RETENTION_10_DAYS_BELOW_SCORE=50
# ≥75 永久保留

# ── 采集调度 ─────────────────────────────────────────────────
# 每日采集开始时间 (UTC, 16:00 UTC = 00:00 北京)
COLLECT_CRON=0 16 * * *
RUN_LOCK_NAME=intelligence_daily_pipeline
RUN_STALE_TIMEOUT_HOURS=12
RUN_DEFAULT_WINDOW_HOURS=24
COLLECTOR_TIMEOUT_S=30
COLLECTOR_DEFAULT_SINCE_HOURS=24
COLLECTOR_FAILURE_DISABLE_THRESHOLD=3
COLLECTOR_GITHUB_PER_PAGE=100
COLLECTOR_HN_MAX_ITEMS=50
COLLECTOR_NVD_RESULTS_PER_PAGE=2000

# 可选：一次性导入候选源的 JSON 文件。运行时以数据库 sources 表为准。
SOURCE_SEED_PATH=config/sources.json

# ── 服务 ─────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8100
API_COMMAND=uvicorn src.main:app
API_TOKEN=
LOG_LEVEL=info
API_DEFAULT_LIMIT=20
API_MAX_LIMIT=100
API_RECENT_DIGESTS_LIMIT=20
SOURCE_SPARK_DAYS=14
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_RECYCLE_S=3600
DATABASE_VERIFY_TLS=false
HEXO_POSTS_DIR=/opt/blog/source/_posts
